# ──────────────────────────────────────────────
# FRONTEND (Vite) — expuestas al navegador
# ──────────────────────────────────────────────

# En Vercel: dejar vacío (las funciones API viven en el mismo dominio, ej. /api/...)
# En desarrollo local con servidor Express separado: http://localhost:4242
VITE_API_URL=

VITE_FIREBASE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890abcd12

# ──────────────────────────────────────────────
# BACKEND (Serverless Functions / Express local)
# Solo se necesitan en Vercel Environment Variables o en .env local
# ──────────────────────────────────────────────

# Solo para desarrollo local con Express:
PORT=4242
APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Prefer STRIPE_PRICE_ID for production catalog pricing.
# If omitted, checkout uses STRIPE_AMOUNT_MXN and STRIPE_PRODUCT_NAME.
STRIPE_PRICE_ID=price_xxx
STRIPE_AMOUNT_MXN=15000
STRIPE_CURRENCY=mxn
STRIPE_PRODUCT_NAME=Acceso premium de por vida - Gage RR Pro
STRIPE_PRODUCT_ID=prod_xxx

# Firebase Admin SDK
# Option A: One-line JSON service account (recomendado para Vercel).
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"firebase-adminsdk-...@your-project.iam.gserviceaccount.com"}

# Option B: Split fields (si no usas FIREBASE_SERVICE_ACCOUNT_KEY).
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-...@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
