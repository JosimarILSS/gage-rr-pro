{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/health", "destination": "/api/health" },
    { "source": "/api/stripe/create-checkout-session", "destination": "/api/stripe/create-checkout-session" },
    { "source": "/api/stripe/confirm-session", "destination": "/api/stripe/confirm-session" },
    { "source": "/api/stripe/webhook", "destination": "/api/stripe/webhook" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
